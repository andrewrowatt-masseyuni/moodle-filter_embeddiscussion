{{!
    @template filter_embeddiscussion/dashboard_placeholder

    Skeleton container rendered in place of the
    {embeddiscussion:latestposts}/{embeddiscussion:dashboard} token.
    The dashboard JS module locates these via data-region and replaces the
    skeleton with the live dashboard once the AJAX payload arrives.

    Classes required for JS:
    * filter-embeddiscussion-dashboard

    Data attributes required for JS:
    * data-region="filter-embeddiscussion-dashboard"
    * data-courseid

    Context variables required for this template:
    * uid (string)
    * courseid (int)

    Example context (json):
    {
        "uid": "embeddisc_dashboard_42",
        "courseid": 42
    }
}}
<div class="filter-embeddiscussion-dashboard" data-region="filter-embeddiscussion-dashboard" id="{{uid}}" data-courseid="{{courseid}}">
  <div class="embeddisc embeddisc-dashboard embeddisc-skeleton" aria-hidden="true">
    <div class="embeddisc-header">
      <div class="embeddisc-skeleton-block embeddisc-skeleton-title"></div>
      <hr class="embeddisc-divider">
    </div>

    <div class="embeddisc-skeleton-block embeddisc-skeleton-name embeddisc-dashboard-skeleton-threadname"></div>

    <div class="embeddisc-skeleton-post">
      <div class="embeddisc-skeleton-block embeddisc-skeleton-avatar"></div>
      <div class="embeddisc-skeleton-post-body">
        <div class="embeddisc-skeleton-meta">
          <div class="embeddisc-skeleton-block embeddisc-skeleton-name"></div>
          <div class="embeddisc-skeleton-block embeddisc-skeleton-role"></div>
        </div>
        <div class="embeddisc-skeleton-block embeddisc-skeleton-time"></div>
        <div class="embeddisc-skeleton-block embeddisc-skeleton-content"></div>
      </div>
    </div>

    <div class="embeddisc-skeleton-post">
      <div class="embeddisc-skeleton-block embeddisc-skeleton-avatar"></div>
      <div class="embeddisc-skeleton-post-body">
        <div class="embeddisc-skeleton-meta">
          <div class="embeddisc-skeleton-block embeddisc-skeleton-name"></div>
        </div>
        <div class="embeddisc-skeleton-block embeddisc-skeleton-time"></div>
        <div class="embeddisc-skeleton-block embeddisc-skeleton-content embeddisc-skeleton-content-short"></div>
      </div>
    </div>

    <div class="sr-only">{{#str}}threadnotinitialised, filter_embeddiscussion{{/str}}</div>
  </div>
</div>
