{{!
    @template filter_embeddiscussion/discussion

    Top-level discussion shell rendered into the filter placeholder.

    Classes required for JS:
    * none

    Data attributes required for JS:
    * data-region="embeddisc-root"
    * data-threadid
    * data-anonymous

    Context variables required for this template:
    * threadid (int)
    * name (string)
    * anonymous (bool)
    * currentuserisanonymous (bool)
    * canpost (bool)
    * canmanageposts (bool)
    * postcount (int)
    * currentuserid (int)
    * currentuseravatar (string, raw HTML)
    * currentuserprofileurl (string, optional)

    Example context (json):
    {
        "threadid": 7,
        "name": "Demo",
        "anonymous": false,
        "currentuserisanonymous": false,
        "canpost": true,
        "canmanageposts": false,
        "postcount": 0,
        "one": false,
        "currentuserid": 2,
        "currentuseravatar": "<img class=\"userpicture\" src=\"https://example.com/u.png\" alt=\"\">",
        "currentuserprofileurl": "https://example.com/user/profile.php?id=2"
    }
}}
<div class="embeddisc" data-region="embeddisc-root" data-threadid="{{threadid}}" data-anonymous="{{#anonymous}}1{{/anonymous}}{{^anonymous}}0{{/anonymous}}">
  {{#currentuserisanonymous}}
    <div class="embeddisc-anonymous-notice" role="note">
      <i class="fa fa-info-circle" aria-hidden="true"></i>
      <span>{{#str}}anonymousnotice, filter_embeddiscussion{{/str}}</span>
    </div>
  {{/currentuserisanonymous}}
  {{#anonymous}}{{#canmanageposts}}
    <div class="embeddisc-anonymous-notice" role="note">
      <i class="fa fa-info-circle" aria-hidden="true"></i>
      <span>{{#str}}anonymousnoticemanager, filter_embeddiscussion{{/str}}</span>
    </div>
  {{/canmanageposts}}{{/anonymous}}

  <div class="embeddisc-header">
    <div class="embeddisc-header-row">
      <div class="embeddisc-title" data-region="post-count">
        {{#postcount}}{{postcount}}{{/postcount}}{{^postcount}}0{{/postcount}}
        {{#str}}comment, filter_embeddiscussion{{/str}}{{#postcount}}{{^one}}s{{/one}}{{/postcount}}{{^postcount}}s{{/postcount}}
      </div>
      <div class="embeddisc-sort">
        <button type="button" class="embeddisc-sort-btn" data-action="sort" data-sort="newest">{{#str}}newest, filter_embeddiscussion{{/str}}</button>
        <button type="button" class="embeddisc-sort-btn embeddisc-sort-active" data-action="sort" data-sort="oldest">{{#str}}oldest, filter_embeddiscussion{{/str}}</button>
      </div>
    </div>
    <hr class="embeddisc-divider">
  </div>

  <div class="embeddisc-composer" data-region="composer">
    <div class="embeddisc-composer-row">
      <div class="embeddisc-post-avatar" data-region="composer-avatar">
        {{#currentuserprofileurl}}<a href="{{currentuserprofileurl}}">{{{currentuseravatar}}}</a>{{/currentuserprofileurl}}
        {{^currentuserprofileurl}}{{{currentuseravatar}}}{{/currentuserprofileurl}}
      </div>
      <div class="embeddisc-composer-main">
        <button type="button" class="embeddisc-composer-trigger" data-region="composer-collapsed"
          data-action="open-composer" {{^canpost}}disabled{{/canpost}}>
          {{#postcount}}{{#str}}jointhediscussion, filter_embeddiscussion{{/str}}{{/postcount}}{{^postcount}}{{#str}}startthediscussion, filter_embeddiscussion{{/str}}{{/postcount}}
        </button>
        <div class="embeddisc-composer-expanded d-none" data-region="composer-expanded">
          <div class="embeddisc-editor" data-region="editor"></div>
          <div class="embeddisc-composer-actions">
            <button type="button" class="btn btn-link" data-action="cancel-compose">{{#str}}cancel, filter_embeddiscussion{{/str}}</button>
            <button type="button" class="btn btn-primary" data-action="submit-compose">{{#str}}comment, filter_embeddiscussion{{/str}}</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="embeddisc-posts" data-region="posts" aria-live="polite"></div>

  <div class="embeddisc-empty {{#postcount}}d-none{{/postcount}}" data-region="empty">
    {{#str}}befirsttocomment, filter_embeddiscussion{{/str}}
  </div>
</div>
