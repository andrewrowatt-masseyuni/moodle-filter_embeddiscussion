<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="filter/embeddiscussion/db" VERSION="2026062900" COMMENT="filter_embeddiscussion database tables"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd"
>
  <TABLES>
    <TABLE NAME="filter_embeddiscussion_thread" COMMENT="Embedded discussion threads, one per unique namehash+context.">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="threadname" TYPE="char" LENGTH="255" NOTNULL="false" COMMENT="Thread name captured when the token was processed"/>
        <FIELD NAME="namehash" TYPE="char" LENGTH="40" NOTNULL="true" COMMENT="SHA1 of the thread lookup string for unique index"/>
        <FIELD NAME="contextid" TYPE="int" LENGTH="10" NOTNULL="true" COMMENT="Context where the thread was first initialised"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" COMMENT="Course where the thread lives (0 if site)"/>
        <FIELD NAME="itemid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" COMMENT="Book chapter id when embedded in a Book chapter, else 0"/>
        <FIELD NAME="anonymous" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0" COMMENT="1 = anonymous handles for students"/>
        <FIELD NAME="handleoffset" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" COMMENT="Random offset into the handle master list"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="contextid_fk" TYPE="foreign" FIELDS="contextid" REFTABLE="context" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="namehash_context" UNIQUE="true" FIELDS="namehash, contextid"/>
        <INDEX NAME="courseid_idx" UNIQUE="false" FIELDS="courseid"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="filter_embeddiscussion_post" COMMENT="Posts and replies in an embedded discussion thread.">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="threadid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="parentid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" COMMENT="0 = top-level"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="content" TYPE="text" NOTNULL="true" COMMENT="Sanitised HTML content"/>
        <FIELD NAME="edited" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="deleted" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="threadid_fk" TYPE="foreign" FIELDS="threadid" REFTABLE="filter_embeddiscussion_thread" REFFIELDS="id"/>
        <KEY NAME="userid_fk" TYPE="foreign" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="thread_parent_idx" UNIQUE="false" FIELDS="threadid, parentid"/>
        <INDEX NAME="userid_idx" UNIQUE="false" FIELDS="userid"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="filter_embeddiscussion_reaction" COMMENT="Emoji reactions on posts.">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="postid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="emoji" TYPE="char" LENGTH="20" NOTNULL="true" COMMENT="Emoji shortcode e.g. thumbsup"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="postid_fk" TYPE="foreign" FIELDS="postid" REFTABLE="filter_embeddiscussion_post" REFFIELDS="id"/>
        <KEY NAME="userid_fk" TYPE="foreign" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="post_user_emoji_unique" UNIQUE="true" FIELDS="postid, userid, emoji" COMMENT="One reaction per emoji per user per post"/>
        <INDEX NAME="postid_idx" UNIQUE="false" FIELDS="postid"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="filter_embeddiscussion_handle" COMMENT="Records the handle index assigned to each anonymous student in a thread.">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="threadid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="handleindex" TYPE="int" LENGTH="10" NOTNULL="true" COMMENT="Position in the static master list, prior to offset"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="threadid_fk" TYPE="foreign" FIELDS="threadid" REFTABLE="filter_embeddiscussion_thread" REFFIELDS="id"/>
        <KEY NAME="userid_fk" TYPE="foreign" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="thread_user_unique" UNIQUE="true" FIELDS="threadid, userid"/>
      </INDEXES>
    </TABLE>
  </TABLES>
</XMLDB>
